# Mongo — los datos se guardan en la BD indicada (por defecto "prueba", misma que ves en Atlas)
MONGO_URI=mongodb://USER:PASS@HOST:27017
# Nombre de la base de datos en Atlas (ej. test). No es otro cluster, solo otra BD dentro del mismo cluster.
MONGO_DB_NAME=test

# Email SMTP (para enviar boletas por Gmail/Hotmail/Outlook)
# Gmail:
# - SMTP_HOST=smtp.gmail.com
# - SMTP_PORT=587
# - SMTP_USER=tu_correo@gmail.com
# - SMTP_PASS=tu_app_password (NO tu clave normal)
# Outlook/Hotmail:
# - SMTP_HOST=smtp.office365.com
# - SMTP_PORT=587
# - SMTP_USER=tu_correo@outlook.com
# - SMTP_PASS=tu_clave_o_app_password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Datos del negocio (para que salgan en la boleta)
BUSINESS_NAME=MI NEGOCIO
BUSINESS_RUC=00000000000
BUSINESS_ADDRESS=Dirección del negocio
BUSINESS_PHONE=999999999
BUSINESS_EMAIL=correo@negocio.com
BUSINESS_WEBSITE=
BUSINESS_LOGO_URL=

# Impuestos (Perú: 0.18)
TAX_RATE=0.18
